# Azure DevOps Remote Configuration
AZURE_DEVOPS_ORGANIZATION=Rapid-AI-Team

# Microsoft Entra ID (OAuth 2.1) App Registration Credentials
ENTRA_TENANT_ID=your-tenant-id-here
ENTRA_CLIENT_ID=your-application-client-id-here
ENTRA_CLIENT_SECRET=your-client-secret-here

# Google Gemini API
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-3.1-flash-lite

# Default project and repository to bypass listing queries and conserve quota
AZURE_DEVOPS_PROJECT=Pulse
AZURE_DEVOPS_REPOSITORY=Pulse
ENABLE_WIKI_SYNC=true
